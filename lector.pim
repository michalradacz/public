    {
      "id": "26aeb53a-0b4b-4e5a-b276-77a48bc28ee8",
      "numericId": 185,
      "title": "Tři druhy promptů pro ovlivnění AI",
      "aspects": [
        "slide"
      ],
      "attributes": {},
      "tags": [
        "📦aiexpert",
        "📦studiář",
        "publikovat",
        "znalosti"
      ],
      "body": "Existují tři druhy promptů, které ovlivní značně výsledek  práce AI\n\n* System prompt: hlavní zadání\n* Context/Instruction prompt: Kontext a chování pro úkol\n* Delivery prompt: Určení výstupu\n\n",
      "links": [],
      "attachments": [],
      "comments": [],
      "confidence": "definitive",
      "inbox": false,
      "archived": false,
      "valid_from": null,
